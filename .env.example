# =========================================
# PICKSPROMLB - VARIABLES DE ENTORNO
# =========================================
# Copia este archivo a .env y llena con tus valores reales
# NUNCA subas el .env al repositorio

# ----- SUPABASE -----
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_secret_xxxxxxxxxxxxx
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxx

# ----- THE ODDS API -----
ODDS_API_KEY=tu_key_de_oddsapi

# ----- OPENWEATHER -----
OPENWEATHER_API_KEY=tu_key_de_openweather

# ----- GEMINI -----
GEMINI_API_KEY=tu_key_de_gemini
GEMINI_MODEL=gemini-2.0-flash-exp

# ----- TELEGRAM -----
TELEGRAM_BOT_TOKEN=8679980286:AAxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=tu_chat_id_personal

# ----- CONFIGURACIÓN GENERAL -----
TIMEZONE=America/New_York
ENVIRONMENT=development
LOG_LEVEL=INFO

# ----- HORAS DE TRIGGERS (relativas al primer juego del día) -----
HOURS_BEFORE_FIRST_GAME=4
HOURS_BEFORE_UPDATE=1
HOURS_AFTER_LAST_GAME=2
